<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  id="Definitions_Example"
  targetNamespace="http://saintpaul.local/bpmn">
  <bpmn:process id="example_process" name="Example Process" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="Início" />
    <bpmn:userTask id="Task_1" name="Ler História" />
    <bpmn:userTask id="Task_2" name="Gerar Especificação" />
    <bpmn:endEvent id="EndEvent_1" name="Fim" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="EndEvent_1" />
  </bpmn:process>
</bpmn:definitions>
