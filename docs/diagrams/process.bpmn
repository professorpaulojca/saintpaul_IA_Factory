<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_1"
  targetNamespace="http://academy-ia-factory/process">
  <bpmn:process id="Process_ApplicationFactory" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="História recebida"/>
    <bpmn:task id="Task_AnalyzeStory" name="Analisar história"/>
    <bpmn:task id="Task_GeneratePrototypes" name="Gerar protótipos"/>
    <bpmn:task id="Task_GenerateSpecs" name="Gerar especificações e diagramas"/>
    <bpmn:task id="Task_GenerateBackend" name="Gerar backend"/>
    <bpmn:task id="Task_GenerateFrontend" name="Gerar frontend"/>
    <bpmn:endEvent id="EndEvent_1" name="Solução revisada"/>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_AnalyzeStory"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_AnalyzeStory" targetRef="Task_GeneratePrototypes"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_GeneratePrototypes" targetRef="Task_GenerateSpecs"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_GenerateSpecs" targetRef="Task_GenerateBackend"/>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_GenerateBackend" targetRef="Task_GenerateFrontend"/>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_GenerateFrontend" targetRef="EndEvent_1"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_ApplicationFactory">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="120" y="160" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AnalyzeStory_di" bpmnElement="Task_AnalyzeStory">
        <dc:Bounds x="210" y="138" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GeneratePrototypes_di" bpmnElement="Task_GeneratePrototypes">
        <dc:Bounds x="390" y="138" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GenerateSpecs_di" bpmnElement="Task_GenerateSpecs">
        <dc:Bounds x="580" y="138" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GenerateBackend_di" bpmnElement="Task_GenerateBackend">
        <dc:Bounds x="800" y="138" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GenerateFrontend_di" bpmnElement="Task_GenerateFrontend">
        <dc:Bounds x="990" y="138" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1190" y="160" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="156" y="178"/>
        <di:waypoint x="210" y="178"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="350" y="178"/>
        <di:waypoint x="390" y="178"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="540" y="178"/>
        <di:waypoint x="580" y="178"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="760" y="178"/>
        <di:waypoint x="800" y="178"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="950" y="178"/>
        <di:waypoint x="990" y="178"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="1140" y="178"/>
        <di:waypoint x="1190" y="178"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
